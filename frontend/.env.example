# Copy this file to .env and fill in your values after infrastructure is deployed

# ALB DNS name — public entry point for all API requests
VITE_API_URL=http://your-lks-alb-dns.us-east-1.elb.amazonaws.com

# Grafana private IP — only reachable from inside lks-monitoring-vpc
VITE_GRAFANA_URL=http://10.1.1.x:3000
