{
  "title": "LKS 2026 — ECS Overview",
  "uid":   "lks2026-ecs",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Users (RDS)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "analytics_requests_total",
          "legendFormat": "requests"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(analytics_requests_total[1m])) * 60",
          "legendFormat": "req/min"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Service — UP / DOWN",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "up{job=\"lks-api-service\"}",
          "legendFormat": "API"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "mappings": [
          { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
        ]
      }
    },
    {
      "id": 4,
      "title": "P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, rate(analytics_request_duration_seconds_bucket[5m])) * 1000",
          "legendFormat": "P95 ms"
        }
      ]
    },
    {
      "id": 5,
      "title": "ECS CPU Utilisation (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "avg(rate(container_cpu_usage_seconds_total{container!=\"\"}[1m])) * 100",
          "legendFormat": "avg CPU %"
        }
      ]
    }
  ]
}
